{
  "version": 2,
  "builds": [
    {
      "src": "server/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/api/index.ts" },
    { "src": "/assets/(.*)", "dest": "client/assets/$1" },
    { "src": "/favicon.ico", "dest": "client/favicon.ico" },
    { "src": "/(.*)", "dest": "client/index.html" }
  ]
}
