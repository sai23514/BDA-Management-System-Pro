# Frontend-only on Vercel.
# Create the Vercel project with Root Directory = "client".
# Do NOT use this file to host the API — chat needs a persistent Node host (Render/Railway).
{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "client/$1" }
  ]
}
