# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/bda-module
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/bda-module

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRE=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# --- Optional integrations (features degrade gracefully when unset) ---

# Email (SMTP) - enables sending emails to leads
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@bdamodule.com

# AI assist (OpenAI) - enables email drafting and lead summaries
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp / SMS (Twilio) - enables messaging leads
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=+14155238886
